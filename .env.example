APP_NAME=media-chatbot
APP_ENV=production
APP_SECRET=change-me-long-random-string
APP_URL=http://localhost:8000
# "text" fejlesztéshez, "json" élesben Grafana/Loki-hoz strukturált loghoz
LOG_FORMAT=text

# Első indításkor létrehozott admin fiók (utána a UI-ból kezelhető)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
SESSION_TTL_DAYS=30

POSTGRES_DB=media_bot
POSTGRES_USER=media_bot
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://media_bot:change-me@postgres:5432/media_bot

REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true

# Sonarr / Radarr (Dockerből Windows hostra: host.docker.internal)
SONARR_URL=http://host.docker.internal:8989
SONARR_API_KEY=change-me-sonarr

RADARR_URL=http://host.docker.internal:7878
RADARR_API_KEY=change-me-radarr

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

TMDB_API_KEY=change-me-tmdb
TMDB_LANGUAGE=hu-HU

TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_ACCESS_TOKEN=

MAX_SERIES_QUALITY=1080p
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

CACHE_DIR=/data/cache
MEDIA_ROOT=/data/media
DOWNLOAD_TEMP_DIR=/data/downloads

SEARCH_CACHE_TTL_SECONDS=3600
STALE_MEDIA_DAYS=30
STORAGE_MIN_FREE_GB=10
STORAGE_DELETE_FILES=false

QUEUE_MAX_WORKERS=2

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
# Vesszővel elválasztott chat ID-k — üresen bárki írhat a botnak!
TELEGRAM_ALLOWED_CHAT_IDS=

DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
# Vesszővel elválasztott guild (szerver) ID-k — üresen minden szerver engedélyezett!
DISCORD_ALLOWED_GUILD_IDS=

# Letöltés-kész értesítés — Sonarr/Radarr Connect → Webhook:
#   URL: {APP_URL}/api/webhooks/{WEBHOOK_SECRET}/sonarr   (ill. /radarr)
#   Method: POST · Triggers: On Import
# Üres WEBHOOK_SECRET esetén a webhook végpont letiltva (404).
WEBHOOK_SECRET=
# Ahová a bot az értesítést küldi (üresen a TELEGRAM_ALLOWED_CHAT_IDS elsőjét használja)
TELEGRAM_NOTIFY_CHAT_ID=
DISCORD_NOTIFY_CHANNEL_ID=

# Torrent kliens (Dashboard widget): qbittorrent | transmission
TORRENT_CLIENT=qbittorrent
TORRENT_URL=
TORRENT_USERNAME=
TORRENT_PASSWORD=
# Befejezett letöltés automatikus törlése ennyi óra után (0 = ki), naplózva
TORRENT_AUTO_DELETE_HOURS=0
TORRENT_AUTO_DELETE_FILES=true

# Média szerverek ("Most nézi" widget)
PLEX_URL=
PLEX_TOKEN=
JELLYFIN_URL=
JELLYFIN_API_KEY=

# Automatikus adatmentés (a Beállítások oldalon is állítható, futás közben)
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP_LAST=14

# Passkey (WebAuthn) — ÉLES környezetben a tényleges domainhez/IP-hez kell
# igazítani, különben a böngésző elutasítja a regisztrációt/bejelentkezést:
#   WEBAUTHN_RP_ID = a domain hostname (pl. "media.example.com" vagy a NAS IP-je, port nélkül)
#   WEBAUTHN_ORIGIN = a teljes URL, ahonnan a frontend fut (pl. "https://media.example.com" vagy "http://192.168.1.50:3000")
# localhoston HTTP is elfogadott, egyébként a legtöbb böngésző HTTPS-t követel meg.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Mediachat
WEBAUTHN_ORIGIN=http://localhost:3100

# Napi hozzáadási limit userenként (0 = korlátlan); admin szerepkör mindig kivétel.
USER_DAILY_ADD_QUOTA=0
